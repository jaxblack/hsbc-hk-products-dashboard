# Optional LLM-backed analysis for the detail sidebar (/api/hk-stocks/llm).
# Copy to ".env" and fill in. Leave empty / unset to keep LLM analysis disabled
# (the UI then shows a "not enabled" hint instead of erroring).
# Restart the FastAPI backend after changing these.

# Provider: openai | azure | ollama   (empty = disabled)
LLM_PROVIDER=

# Model name (openai / ollama) or Azure *deployment* name
LLM_MODEL=

# API key / secret. Not needed for ollama (local).
LLM_API_KEY=

# Base URL.
#   openai  -> https://api.openai.com/v1   (default, can omit)
#   azure   -> https://<your-resource>.openai.azure.com
#   ollama  -> http://localhost:11434/v1   (default, can omit)
LLM_BASE_URL=

# Azure only.
LLM_API_VERSION=2024-06-01
